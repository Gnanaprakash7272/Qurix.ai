# Browser Use SDK 
BROWSER_USE_API_KEY=your_browser_use_cloud_api_key_here

# LLM Providers (Required for local execution)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# OAuth Configuration (Required for Google/GitHub Login)
SESSION_SECRET_KEY=super_secret_session_key_for_oauth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
